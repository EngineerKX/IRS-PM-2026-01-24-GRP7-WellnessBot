# --- NLU Provider ---
# Which LLM to use for NLU extraction: "openai" or "claude"
NLU_PROVIDER=openai

# --- OpenAI (used when NLU_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic / Claude (used when NLU_PROVIDER=claude) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- General ---
MOCK_NLU=0
LOGGING_ENABLED=1
LOG_DIR=logs
DEBUG_PIPELINE=0
APP_VERSION=v2
